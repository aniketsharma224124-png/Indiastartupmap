rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USERS / PROFILES ────────────────────────────────────────
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── STARTUPS ────────────────────────────────────────────────
    // Public read (map needs it unauthenticated).
    // Any logged-in user can create (listing flow).
    // Only the owner can update/delete.
    match /startups/{docId} {
      allow read:             if true;
      allow create:           if request.auth != null;
      allow update, delete:   if request.auth != null
        && (resource.data.uid          == request.auth.uid
         || resource.data.founder_uid  == request.auth.uid);
    }

    // ── INVESTORS ───────────────────────────────────────────────
    match /investors/{docId} {
      allow read:             if true;
      allow create:           if request.auth != null;
      allow update, delete:   if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ── INVESTOR INTEREST ────────────────────────────────────────
    // FIX: founders must be able to read interest marks for their startup.
    // Allow read if:
    //   (a) the investor who marked it is reading it, OR
    //   (b) a logged-in user is reading it (founder checking their inbox)
    //       — we scope this to authenticated reads; the startup_id filter
    //         happens in the query, not the rule.
    match /investor_interest/{docId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.investor_uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.investor_uid == request.auth.uid;
    }

    // ── INTRO REQUESTS ───────────────────────────────────────────
    // FIX: covers founder_to_investor, investor_to_founder AND
    //      founder_to_founder directions.
    // Read:   any authenticated user (queries are scoped by investor_id,
    //         investor_uid, founder_email, or startup_id in code).
    // Create: any logged-in user (founder or investor can initiate).
    // Update: either party (to accept/decline).
    match /intro_requests/{docId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (resource.data.investor_id          == request.auth.uid
         || resource.data.investor_uid         == request.auth.uid
         || resource.data.founder_email        == request.auth.token.email
         || resource.data.recipient_uid        == request.auth.uid);
    }

    // ── SAVED STARTUPS ───────────────────────────────────────────
    match /saved_startups/{docId} {
      allow read, delete: if request.auth != null
        && resource.data.investor_uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.investor_uid == request.auth.uid;
    }

    // ── PAYMENTS / ORDERS ────────────────────────────────────────
    match /payments/{docId} {
      allow read:   if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null;
    }

    // ── FALLBACK ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
